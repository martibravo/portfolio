---
import Base from '../../layouts/Base.astro';
import TagList from '../../components/TagList.astro';
import Figure from '../../components/Figure.astro';
import TwoCol from '../../components/TwoCol.astro';
import ThreeCol from '../../components/ThreeCol.astro';
import ImageGrid from '../../components/ImageGrid.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../../config';
import type { CategoryId } from '../../config';

export async function getStaticPaths() {
  const paths = [];
  for (const cat of CATEGORIES) {
    const entries = await getCollection(cat.id);
    for (const entry of entries) {
      paths.push({
        params: { category: cat.id, slug: entry.slug },
        props:  { entry, category: cat },
      });
    }
  }
  return paths;
}

const { entry, category } = Astro.props;
const { Content } = await entry.render();

const dateStr = entry.data.date.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<Base title={entry.data.title} description={entry.data.description}>
  <a href={`/${category.id}/`} class="back">{category.label}</a>

  <article>
    <header class="article-header">
      <h1 class="article-title">{entry.data.title}</h1>
      <div class="article-meta">
        <time datetime={entry.data.date.toISOString()}>{dateStr}</time>
        {entry.data.tags.length > 0 && (
          <TagList tags={entry.data.tags} />
        )}
      </div>
    </header>

    <div class="prose">
      <Content components={{ Figure, TwoCol, ThreeCol, ImageGrid }} />
    </div>
  </article>
</Base>
